---
// src/pages/index.astro
import '../styles/global.css';
import '../styles/global.css';
import '@fontsource/koulen';
import '@fontsource/kumbh-sans';
import '@fontsource/inter';
---

<!DOCTYPE html>
<html lang="en">
<link rel="canonical" href="https://www.a2bcargo.com/" />

<!-- Open Graph (para compartir en redes/WhatsApp/LinkedIn) -->
<meta property="og:title" content="A2B Cargo — Expert Freight Forwarding & Export Services" />
<meta property="og:description" content="A2B Cargo LLC handles all aspects of your shipment: AES filing, export documentation, ocean & truck rates, and logistics support." />
<meta property="og:image" content="https://www.a2bcargo.com/assets/og-image.jpg" />
<meta property="og:url" content="https://www.a2bcargo.com/" />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>A2B Cargo - We'll Get It There</title>

<meta name="description" content="A2B Cargo LLC, Kennesaw GA — Freight forwarding, AES filing, ocean & truck rate quotation, export documentation and consulting. Door-to-door service with a single point of contact." />
</head>
<body>
  <!-- ══ NAVBAR ══ -->
  <nav class="navbar">
    <span class="navbar__brand">A2B Cargo</span>
  </nav>

  <!-- ══ HERO — aerial ship ══ -->
  <section class="hero">
    <img
      class="hero__img"
      src="../assets/main-photo.jpg"
      alt="Aerial view of a cargo container ship"
      fetchpriority="high"
    />
    <div class="hero__overlay">
      <h1 class="hero__tagline">All Your Shipping Needs in One Place</h1>
    </div>
  </section>

<div class="page-content">
  <!-- ══ SERVICES — white card floating over hero ══ -->
  <section class="services-section">
    <div class="services-card">

      <!-- Logo -->
      <div class="logo-wrap">
        <img class="logo-wrap__img" src="../assets/a2bcargo.png" alt="A2B Cargo Logo" />
      </div>

      <p class="services-title">Our Services</p>
      <p class="services-subtitle">Let us help you with any of our areas of expertise</p>

      <div class="services-grid">
        <div class="service-card">
          <span class="service-card__label">Logistics </br> support</span>
          <img src="../assets/conveyor-belt.svg" alt="Conveyor belt"/>
        </div>
        <div class="service-card">
          <span class="service-card__label">AES filing</span>
        <img src="../assets/files.svg" alt="File folder"/>
        </div>
        <div class="service-card">
          <span class="service-card__label">Ocean & Truck Rate Quotation</span>
           <img src="../assets/safety.svg"/ alt="Safety shield">
        </div>
        <div class="service-card">
          <span class="service-card__label">Export documentation</span>
           <img src="../assets/cases.svg" alt="Briefcases"/>
        </div>
        <div class="service-card">
          <span class="service-card__label">Consulting export</br> regulations</span>
           <img src="../assets/boat.svg" alt="Boat sailing"/>
        </div>
        <div class="service-card">
          <span class="service-card__label">Contract </br> negotiations</span>
           <img src="../assets/conveyor-belt.svg" alt="Conveyor belt"/>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ ABOUT US ══ -->
  <section class="about-section">
    <div class="about-outer">
      <div class="about-bg">

        <h2 class="about-heading">About Us</h2>

        <div class="about-inner">
          <div class="about-left">
            <p class="about-subheading">Not the biggest, but the best</p>
            <p class="about-text">
              We can handle all aspects of your shipment from scheduling load
              appointments at your plant or warehouse, setting up trucks to transport
              the cargo to port of load, filling export declarations with US Customs
              and issuance of export documents.
            </p>
          </div>
          <div class="about-right">
            <img
              class="about-img"
              src="/assets/cargo-ship.jpg"
              alt="Container ship at port"
              loading="lazy"
            />
          </div>
        </div>

        <div class="about-badges">
          <div class="about-badge about-badge--left">The job is not done until your cargo arrives at the destination</div>
          <div class="about-badge about-badge--center">Single point of contact</div>
          <div class="about-badge about-badge--right">Cost effective and reliable forwarding service</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ WHAT WE PROVIDE ══ -->
  <section class="provides-section">
    <div class="provides-outer">
      <div class="provides-banner">
        <h2>What We Provide</h2>
      </div>
      <div class="provides-row">
        <div class="provides-item">Door-to-door service</div>
        <div class="provides-item">Accurate and timely documentation</div>
        <div class="provides-item">Competitive ocean rates</div>
      </div>
      <div class="provides-row provides-row--2col">
        <div class="provides-item">Experienced and helpful staff</div>
        <div class="provides-item">Always a live person to contact</div>
      </div>
    </div>
  </section>
    <!-- ══ ALWAYS HERE BANNER ══ -->
  <!-- ══ CONTACT ══ -->
  <section class="contact-section" id="contact">
    <!-- Background image: stacked containers -->
    <img
      class="contact-section__bgimg"
      src="/assets/containers.jpg"
      alt="Containers"
      aria-hidden="true"
      loading="lazy"
    />
  <div class="always-section">
    <div class="always-section__overlay">
      <div class="always-pill">
        <h2>ALWAYS HERE TO HELP YOU</h2>
      </div>
    </div>
  </div>
    <div class="contact-section__inner">

      <!-- Three info cards -->
      <div class="info-row">
        <div class="info-card">
          <strong>Main:</strong> (678) 229–2539<br/>
          <strong>Cell:</strong> (678) 934–1335
        </div>
        <div class="info-card">
          A2B Cargo LLC<br/>
          1255 Rolling Oaks Drive<br/>
          Kennesaw, GA 30152<br/>
          FMC# 0205050F
        </div>
        <div class="info-card">
          <a href="mailto:Dave@a2bcargo.com">Dave@a2bcargo.com</a>
        </div>
      </div>

      <!-- Netlify Form -->
      <div class="contact-form-bckr">
        <p class="contact-form-label">Contact us</p>
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          accept-charset="UTF-8"
          class="contact-form"
          action="/success.html"
        >
          <input type="hidden" name="form-name" value="contact" placeholder="John"/>
          <p class="form-honeypot" aria-hidden="true">
            <label>
              Do not fill this field if you are human:
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <!-- Left: Name / Email / Phone -->
          <div class="form-col-left">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="phone">*Phone</label>
              <input type="tel" id="phone" name="phone" />
            </div>
          </div>

          <!-- Right: Message -->
          <div class="form-col-right">
            <div class="form-group--message">
              <label for="message">Message</label>
              <textarea id="message" name="message" required></textarea>
            </div>
          </div>

          <!-- Submit -->
          <div class="form-submit-row">
            <button type="submit" class="btn-submit">submit</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <div class="footbar"></div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FreightForwarder",
    "name": "A2B Cargo LLC",
    "url": "https://www.a2bcargo.com",
    "telephone": "+16782292539",
    "email": "Dave@a2bcargo.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1255 Rolling Oaks Drive",
      "addressLocality": "Kennesaw",
      "addressRegion": "GA",
      "postalCode": "30152",
      "addressCountry": "US"
    },
    "description": "Expert freight forwarding, AES filing, export documentation and logistics support."
  }
  </script>

</body>
</html>
<script>
  const heroImg = document.querySelector('.hero__img') as HTMLElement | null;

  window.addEventListener('scroll', () => {
    const scrollValue = window.scrollY;
    if (heroImg) {
      heroImg.style.transform = `translateY(${scrollValue * 0.9}px) scale(-1)`;
    }
  });
</script>
