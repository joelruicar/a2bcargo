---
import '../styles/global.css';
import { Font } from "astro:assets";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thank You — A2B Cargo</title>
</head>
<body style="background:var(--navy-dark); display:flex; align-items:center; justify-content:center; min-height:100vh; flex-direction:column; gap:1.5rem; text-align:center; padding:2rem;">
  <h1 style="font-family:var(--font-pacifico),cursive; color:var(--amber); font-size:2.5rem; letter-spacing:.02em;">Message Received!</h1>
  <p style="color:rgba(255,255,255,.8); font-size:1.1rem; max-width:400px;">
    Thank you for reaching out to A2B Cargo. We'll get back to you as soon as possible.
  </p>
  <a href="/" style="background:var(--amber); color:#fff; padding:.75rem 2rem; border-radius:6px; font-family:var(--font-pacifico),cursive; font-weight:400; letter-spacing:.02em; text-transform:none;">
    Back to Home
  </a>
</body>
</html>
